# ── Python backend ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.egg
pip-wheel-metadata/

# ── Node / Frontend ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
dist/
.vite/
*.local

# ── Tauri / Rust ──────────────────────────────────────────────────
# `src-tauri/target/` 只匹配「仓库根目录下」的 Tauri 工程；本仓库在 `apps/desktop/src-tauri/`，
# 需用 `**/` 才能忽略任意深度的 `src-tauri/target`（与旧机「根目录就是 desktop」等布局不同）。
src-tauri/target/
**/src-tauri/target/
*.pdb
# Sidecar binaries are built by CI (PyInstaller); only .gitkeep is tracked
apps/desktop/src-tauri/binaries/trpg-backend-*

# ── App data (local runtime data, never commit) ───────────────────
trpg-workbench-data/
*.db
*.db-shm
*.db-wal

# ── Secrets & credentials ────────────────────────────────────────
.env
.env.*
!.env.example
*.key
secrets.json

# ── Vector index (large binary files) ───────────────────────────
*.lance/
*.hnswlib
index/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log

# ── OS & editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Test / coverage ──────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Skill eval workspaces (generated, not source) ────────────────
.agents/skills/*-workspace/

# ── Local development plans ──────────────────────────────────────
# .agents/plans/ is intentionally tracked
.githooks

# ── UI snapshot screenshots (binary, for human review only) ──────
docs/ui-snapshots/**/screenshots/

# ── Playwright-cli ───────────────────────────────────────────────
.playwright-cli