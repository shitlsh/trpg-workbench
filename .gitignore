*.db
*.db-shm
*.db-wal

# ── Secrets & credentials ────────────────────────────────────────
.env
.env.*
!.env.example
*.key
secrets.json

# ── Vector index (large binary files) ───────────────────────────
*.lance/
*.hnswlib
index/

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log

# ── OS & editor ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
