# ── Python backend ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.egg
pip-wheel-metadata/

# ── Node / Frontend ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
dist/
.vite/
*.local

# ── Tauri / Rust ──────────────────────────────────────────────────
src-tauri/target/
*.pdb

# ── App data (local runtime data, never commit) ───────────────────
